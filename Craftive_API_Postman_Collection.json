						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{jwt_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Siti Rahayu Updated\",\n    \"email\": \"siti@craftive.id\",\n    \"phone\": \"081234567890\",\n    \"address\": \"Jl. Batik No.5, Yogyakarta\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/profile",
							"host": ["{{base_url}}"],
							"path": ["auth", "profile"]
						},
						"description": "Memperbarui data profil pengguna yang sedang login."
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{jwt_token}}"}
						],
						"url": {
							"raw": "{{base_url}}/auth/refresh",
							"host": ["{{base_url}}"],
							"path": ["auth", "refresh"]
						},
						"description": "Memperbarui token JWT sebelum kadaluarsa."
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{jwt_token}}"}
						],
						"url": {
							"raw": "{{base_url}}/auth/logout",
							"host": ["{{base_url}}"],
							"path": ["auth", "logout"]
						},
						"description": "Keluar dan invalidasi token JWT."
					}
				},
				{
					"name": "Forgot Password (OTP)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"siti@craftive.id\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/forgot-password",
							"host": ["{{base_url}}"],
							"path": ["auth", "forgot-password"]
						},
						"description": "Meminta kode OTP untuk reset password."
					}
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"siti@craftive.id\",\n    \"otp\": \"123456\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/reset-password",
							"host": ["{{base_url}}"],
							"path": ["auth", "reset-password"]
						},
						"description": "Reset password menggunakan OTP yang diterima."
					}
				},
				{
					"name": "Basic Auth - Profile",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"}
						],
						"auth": {
							"type": "basic",
							"basic": [
								{"key": "username", "value": "siti@craftive.id"},
								{"key": "password", "value": "password123"}
							]
						},
						"url": {
							"raw": "{{base_url}}/profile/me",
							"host": ["{{base_url}}"],
							"path": ["profile", "me"]
						},
						"description": "Contoh HTTP Basic Auth - mengirim email:password langsung tanpa JWT."
					}
				}
			]
		},
