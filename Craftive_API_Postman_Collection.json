{
	"info": {
		"_postman_id": "craftive-api-collection-2026",
		"name": "🎨 Craftive API - UAS Collection",
		"description": "Koleksi endpoint REST API Craftive - Marketplace Kerajinan Tangan Premium\n\n**Cara pakai:**\n1. Set variable `base_url` = `http://localhost:8000/api`\n2. Set variable `api_key` = `craftive-secret-key-2024`\n3. Login dulu di folder Auth → simpan token ke variable `jwt_token`\n4. Semua request protected akan otomatis pakai token tsb",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "api_key",
			"value": "craftive-secret-key-2024",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "🔐 Auth",
			"description": "Endpoint Autentikasi: Register, Login, Logout, dan manajemen profil menggunakan JWT.",
			"item": [
				{
					"name": "Register (Buyer)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('jwt_token', json.token);",
									"    console.log('Token tersimpan:', json.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Siti Pembeli\",\n    \"email\": \"siti@craftive.id\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"buyer\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						},
						"description": "Mendaftarkan akun buyer baru. Setelah berhasil, token JWT otomatis tersimpan ke variable koleksi."
					}
				},
				{
					"name": "Register (Seller)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Budi Pengrajin\",\n    \"email\": \"budi.seller@craftive.id\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"seller\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						},
						"description": "Mendaftarkan akun seller (artisan/pengrajin) baru."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.collectionVariables.set('jwt_token', json.access_token);",
									"    console.log('✅ Token JWT tersimpan!');",
									"    console.log('User:', json.user.name, '| Role:', json.user.role);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"siti@craftive.id\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Login dan dapatkan token JWT. Token otomatis tersimpan ke variable `jwt_token` via test script."
					}
				},
				{
					"name": "Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.collectionVariables.set('jwt_token', json.access_token);",
									"    console.log('✅ Admin token tersimpan!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@craftive.id\",\n    \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Login sebagai Admin untuk mengakses endpoint admin."
					}
				},
				{
					"name": "Me (Profil Sendiri)",
