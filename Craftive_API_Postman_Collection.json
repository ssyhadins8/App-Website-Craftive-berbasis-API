						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{jwt_token}}"}
						],
						"url": {
							"raw": "{{base_url}}/auth/me",
							"host": ["{{base_url}}"],
							"path": ["auth", "me"]
						},
						"description": "Melihat data profil pengguna yang sedang login."
					}
				},
				{
					"name": "Update Profile",
